{
  "compilerOptions": {
    "baseUrl": ".",

    "paths": {

      "@/*": ["src/*"]

    },

    "ignoreDeprecations": "6.0",
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "lib": [
      "ESNext"
    ],
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "types": [
        "./worker-configuration.d.ts",
        "node"
    ]
  
  },
}